# Copy this file to deploy/gluetun.env and fill in the values required by your
# VPN provider. This file is loaded only by the Gluetun container.

VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=replace-with-wireguard-private-key
WIREGUARD_ADDRESSES=replace-with-wireguard-addresses

# Allow the published SwarmOtter API/Web UI control-plane port through
# Gluetun's default-interface firewall.
FIREWALL_INPUT_PORTS=9091

# Common custom WireGuard provider values. Uncomment when your provider needs
# them, or use provider-specific Gluetun variables instead.
# WIREGUARD_PUBLIC_KEY=
# WIREGUARD_PRESHARED_KEY=
# WIREGUARD_ENDPOINT_IP=
# WIREGUARD_ENDPOINT_PORT=
# SERVER_COUNTRIES=
# SERVER_CITIES=
# FIREWALL_OUTBOUND_SUBNETS=
