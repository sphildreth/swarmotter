# Copy this file to deploy/.env and replace all placeholder values before use.

TZ=America/Chicago

# SwarmOtter image and API.
SWARMOTTER_IMAGE=ghcr.io/sphildreth/swarmotter:latest
SWARMOTTER_WEB_PORT=9091
# Set false only when the reachable LAN is the intended control-plane boundary.
SWARMOTTER_API_REQUIRE_AUTH=true
SWARMOTTER_API_TOKEN=replace-with-a-long-random-token

# Host paths. SWARMOTTER_CONFIG_DIR is mounted as a directory so validated
# settings replacement can atomically rename swarmotter.toml. The supplied
# container config explicitly disables in-app containment only because Compose
# joins SwarmOtter to Gluetun's firewall/kill-switch network namespace.
GLUETUN_STATE_DIR=/srv/swarmotter/gluetun
GLUETUN_ENV_FILE=gluetun.env
SWARMOTTER_CONFIG_DIR=/srv/swarmotter/config
SWARMOTTER_DOWNLOADS=/srv/swarmotter/downloads
SWARMOTTER_INCOMPLETE=/srv/swarmotter/incomplete
SWARMOTTER_STATE=/srv/swarmotter/state
