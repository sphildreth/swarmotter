[Unit]
Description=SwarmOtter BitTorrent daemon
Documentation=https://github.com/sphildreth/swarmotter
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=swarmotter
Group=swarmotter

# Configuration file.
Environment=SWARMOTTER_CONFIG=/etc/swarmotter/swarmotter.toml
ExecStart=/usr/bin/swarmotterd --config /etc/swarmotter/swarmotter.toml

# Persistent state and download directories.
StateDirectory=swarmotter
ReadWritePaths=/etc/swarmotter /var/lib/swarmotter /data/downloads /data/incomplete
UMask=0077

# Large libraries need enough descriptors for peer sockets and open files.
LimitNOFILE=65536

# Hardening.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=false
RestrictSUIDSGID=true
LockPersonality=true

# Restart policy.
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
