# SwarmOtter example configuration file.
#
# SwarmOtter is configured through this file plus environment variable
# overrides (prefix SWARMOTTER_, nested fields separated by __).
# Invalid required configuration produces clear startup errors.

# --- Control plane (API + Web UI) ---
[api]
bind_address = "127.0.0.1:9091"
# Set require_auth = true and auth_token to enable API authentication.
require_auth = false
# auth_token = "change-me"
# Maximum API request body size in bytes.
max_request_body_bytes = 16777216

# --- Compatibility APIs ---
[compatibility.transmission]
enabled = false

[compatibility.qbittorrent]
enabled = false

# --- Storage ---
[storage]
download_dir = "/data/downloads"
incomplete_dir = "/data/incomplete"
minimum_free_space_bytes = 0
minimum_free_space_percent = 0
preallocate = false
sparse = true

# --- Network containment (release-critical) ---
# Strict mode forces all torrent traffic through the configured path and
# fails closed if that path is unavailable. See design/vpn-network-containment.md.
[network]
mode = "strict"
required_interface = "br0"
# Optional for static-address deployments; omit for DHCP/SLAAC interfaces.
# required_source_ipv4 = "192.0.2.10"
# required_source_ipv6 = "2001:db8::10"
allow_ipv6 = true
fail_closed = true
validate_route = true
# Linux/systemd-resolved interface DNS is validated against required_interface
# before torrent hostname resolution is allowed.
validate_dns = true

# --- Autopilot ---
[autopilot]
# Optional: disabled (off), observe (reasons only), or act (bounded actions).
mode = "act"

# --- Torrent peer listener (data plane) ---
[torrent]
listen_port = 51413
allow_ipv6 = true
# Enable uTP (BEP 29) peer connections over the contained UDP socket. When
# true, the engine attempts uTP alongside TCP (see utp_prefer_tcp). All uTP
# traffic fail-closes with the rest of the data plane.
utp_enabled = true
# When uTP is enabled, prefer TCP (try TCP first, fall back to uTP). Set to
# false to prefer uTP.
utp_prefer_tcp = true
# TCP peer-wire encryption policy: disabled, preferred, or required. Preferred
# attempts MSE/PE first while preserving plaintext fallback for compatibility.
encryption_mode = "preferred"
# Selfish mode removes a torrent from SwarmOtter immediately after the download
# completes. Already-completed managed records are also removed on runtime
# reconciliation. Downloaded files are kept, but SwarmOtter will not seed the
# torrent after completion. Useful when SwarmOtter should fetch content and then
# stop managing the torrent without seeding. Default is false (normal completion
# and seeding behavior).
selfish = false

# --- Bandwidth ---
[bandwidth]
global_download = 0       # bytes/sec, 0 = unlimited
global_upload = 0
alt_download = 0
alt_upload = 0
alt_enabled = false
max_peers = 0
max_peers_per_torrent = 0

# --- Queue ---
[queue]
max_active_downloads = 5
max_active_metadata_fetches = 100
max_active_seeds = 5
auto_start = true

# --- Seeding / ratio ---
[seeding]
global_ratio_limit = 2.0
global_idle_limit = 1800   # seconds

# --- DHT ---
[dht]
enabled = true
port = 51413
bootstrap_nodes = [
    "dht.transmissionbt.com:6881",
    "router.bittorrent.com:6881",
]

# --- PEX ---
[pex]
enabled = true
max_peers = 0

# --- Watch folders (uncomment and adjust) ---
# [[watch]]
# path = "/data/watch"
# recursive = false
# label = "auto"
# start_behavior = "start"   # or "paused"
# delete_after_import = true

# --- Logging ---
[logging]
level = "info"
json = false
# Log to stderr/journal and to a file by default. If file_path is omitted,
# SwarmOtter writes to $XDG_STATE_HOME/swarmotter/swarmotterd.log or
# ~/.local/state/swarmotter/swarmotterd.log.
file = true
# file_path = "~/.local/state/swarmotter/swarmotterd.log"
